# Claude Code session/cache ephemera (tool-created, not user-edited)
.claude/cache/
.claude/history/
.claude/sessions/
.claude/tmp/

# Personal-scope settings override (not for commit)
.claude/settings.local.json

# Operator-local Codex overrides belong in AGENTS.local.md. The shipped
# AGENTS.md is the Codex adapter for the same team contract as CLAUDE.md.
AGENTS.local.md

# SME local-only material — per IP policy, external/copyrighted material
# stays out of the repo. Cited in docs/sme/<domain>/INVENTORY.md.
docs/sme/*/local/
docs/sme/local/

# OS
.DS_Store
Thumbs.db

# Editors
.idea/
.vscode/
*.swp

# Common build/env artifacts (adjust to your stack)
node_modules/
__pycache__/
*.pyc
*.log
# Audit logs are binding artefacts — keep tracked.
!docs/audits/*.log
.env
.env.local
dist/
build/
target/

# Build-time TOC strip mirror (spec 010 D-1, D-5). Regenerated locally by
# scripts/strip-toc.sh; never committed.
.model-view/

# spec 008 fixture snapshots are gitignored + regenerated per clone
# via scripts/generate-fixture-snapshots.sh --all (see snapshots/README.md)
tests/release-gate/snapshots/*
!tests/release-gate/snapshots/README.md

# Operator-local dogfood fixtures; never commit (project-specific content)
.dogfood-fixtures/

# Lowercase stale variant of docs/pm/TOKEN_LEDGER.md (#160). Some agent
# code paths derive the filename by lowercasing the conceptual name; the
# canonical file is docs/pm/TOKEN_LEDGER.md (uppercase). Ignoring the
# lowercase variant stops it appearing as untracked on every commit cycle.
docs/pm/token-ledger.md
