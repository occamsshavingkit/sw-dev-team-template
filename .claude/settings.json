{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(*)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(shred *)",
      "Bash(truncate *)",
      "Bash(rm *)",
      "Bash(chmod 777 *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git checkout -- *)",
      "Bash(git restore --*)",
      "Bash(git branch -D *)",
      "Bash(git push --force*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git push -f *)",
      "Bash(git push -f)",
      "Bash(git push --delete*)",
      "Bash(git push --mirror*)"
    ]
  },
  "env": {},
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-.}/scripts/hooks/customer-notes-guard.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-.}/scripts/hooks/tech-lead-authoring-guard.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "SWDT_HANDOFF_GATES=warn python3 \"${CLAUDE_PROJECT_DIR:-.}/scripts/hooks/handoff-pre-tool-gate.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-.}/scripts/hooks/customer-notes-guard.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-.}/scripts/hooks/tech-lead-authoring-guard.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "SWDT_HANDOFF_GATES=warn python3 \"${CLAUDE_PROJECT_DIR:-.}/scripts/hooks/handoff-pre-tool-gate.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-.}/scripts/hooks/customer-notes-guard.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-.}/scripts/hooks/tech-lead-authoring-guard.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "SWDT_HANDOFF_GATES=warn python3 \"${CLAUDE_PROJECT_DIR:-.}/scripts/hooks/handoff-pre-tool-gate.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-.}/scripts/hooks/customer-notes-guard.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-.}/scripts/hooks/tech-lead-authoring-guard.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "SWDT_HANDOFF_GATES=warn python3 \"${CLAUDE_PROJECT_DIR:-.}/scripts/hooks/handoff-pre-tool-gate.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-.}/scripts/hooks/subcall-limit-guard.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "SWDT_HANDOFF_GATES=warn python3 \"${CLAUDE_PROJECT_DIR:-.}/scripts/hooks/handoff-task-completed-gate.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "SWDT_HANDOFF_GATES=warn python3 \"${CLAUDE_PROJECT_DIR:-.}/scripts/hooks/handoff-task-created-gate.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "SWDT_HANDOFF_GATES=warn python3 \"${CLAUDE_PROJECT_DIR:-.}/scripts/hooks/handoff-subagent-stop-gate.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "SWDT_HANDOFF_GATES=warn python3 \"${CLAUDE_PROJECT_DIR:-.}/scripts/hooks/handoff-stop-gate.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "SWDT_HANDOFF_GATES=warn python3 \"${CLAUDE_PROJECT_DIR:-.}/scripts/hooks/handoff-record-activity.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -x \"${CLAUDE_PROJECT_DIR:-.}/scripts/version-check.sh\" ] && \"${CLAUDE_PROJECT_DIR:-.}/scripts/version-check.sh\" 2>&1 || true",
            "timeout": 10,
            "statusMessage": "Checking template version..."
          },
          {
            "type": "command",
            "command": "[ -x \"${CLAUDE_PROJECT_DIR:-.}/scripts/hooks/atomic-question-reminder.sh\" ] && \"${CLAUDE_PROJECT_DIR:-.}/scripts/hooks/atomic-question-reminder.sh\" 2>&1 || true",
            "timeout": 5,
            "statusMessage": "Atomic-question rule reminder..."
          },
          {
            "type": "command",
            "command": "[ -x \"${CLAUDE_PROJECT_DIR:-.}/scripts/hooks/role-routing-reminder.sh\" ] && \"${CLAUDE_PROJECT_DIR:-.}/scripts/hooks/role-routing-reminder.sh\" 2>&1 || true",
            "timeout": 5,
            "statusMessage": "Role-routing rule reminder..."
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-.}/scripts/hooks/subcall-limit-reset.py\"",
            "timeout": 5,
            "statusMessage": "Resetting subagent subcall budget..."
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "[ -x \"${CLAUDE_PROJECT_DIR:-.}/scripts/hooks/post-compact-refresh.sh\" ] && \"${CLAUDE_PROJECT_DIR:-.}/scripts/hooks/post-compact-refresh.sh\" 2>&1 || true",
            "timeout": 5,
            "statusMessage": "Post-compaction refresh directive..."
          }
        ]
      }
    ]
  }
}
