{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit(/home/quackdcs/SWEProj/**)",
      "Write(/home/quackdcs/SWEProj/**)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(which *)",
      "Bash(test *)",
      "Bash(stat *)",
      "Bash(tree *)",
      "Bash(diff *)",
      "Bash(diff -q *)",
      "Bash(diff -r *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git remote*)",
      "Bash(git config --get*)",
      "Bash(git rev-parse*)",
      "Bash(git ls-files*)",
      "Bash(mkdir -p /home/quackdcs/SWEProj/**)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(sudo *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git checkout -- *)",
      "Bash(git restore --*)",
      "Bash(git branch -D *)",
      "Bash(chmod 777 *)",
      "Bash(dd *)",
      "Bash(mkfs *)"
    ],
    "autoMode": {
      "allow": [
        "$defaults",
        "Edit(/home/quackdcs/SWEProj/**) — project-managed agent contracts and templates; the project owns these and they are tracked in git.",
        "Write(/home/quackdcs/SWEProj/**) — same as above; new artifacts under the project root are project-owned."
      ]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR}/scripts/hooks/customer-notes-guard.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR}/scripts/hooks/tech-lead-authoring-guard.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR}/scripts/hooks/customer-notes-guard.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR}/scripts/hooks/tech-lead-authoring-guard.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR}/scripts/hooks/customer-notes-guard.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR}/scripts/hooks/tech-lead-authoring-guard.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR}/scripts/hooks/customer-notes-guard.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR}/scripts/hooks/tech-lead-authoring-guard.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -x ./scripts/version-check.sh ] && ./scripts/version-check.sh 2>&1 || true",
            "timeout": 10,
            "statusMessage": "Checking template version..."
          },
          {
            "type": "command",
            "command": "[ -x \"${CLAUDE_PROJECT_DIR}/scripts/hooks/atomic-question-reminder.sh\" ] && \"${CLAUDE_PROJECT_DIR}/scripts/hooks/atomic-question-reminder.sh\" 2>&1 || true",
            "timeout": 5,
            "statusMessage": "Atomic-question rule reminder..."
          },
          {
            "type": "command",
            "command": "[ -x \"${CLAUDE_PROJECT_DIR}/scripts/hooks/role-routing-reminder.sh\" ] && \"${CLAUDE_PROJECT_DIR}/scripts/hooks/role-routing-reminder.sh\" 2>&1 || true",
            "timeout": 5,
            "statusMessage": "Role-routing rule reminder..."
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "[ -x \"${CLAUDE_PROJECT_DIR}/scripts/hooks/post-compact-refresh.sh\" ] && \"${CLAUDE_PROJECT_DIR}/scripts/hooks/post-compact-refresh.sh\" 2>&1 || true",
            "timeout": 5,
            "statusMessage": "Post-compaction refresh directive..."
          }
        ]
      }
    ]
  }
}
